---
import '@/styles/globals.css';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description = 'James Ding – ML Engineer & Data Scientist. MDSA, University of Calgary. Background in aviation, logistics & agriculture. TN visa eligible, open to US roles.',
  ogImage = '/og-default.png',
  canonical,
} = Astro.props;

const siteUrl = 'https://dingjames.com';
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
---

<!doctype html>
<html lang="en" class="">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#7bffd4" />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={`${siteUrl}${ogImage}`} />
    <meta property="og:site_name"   content="James Ding" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:site"        content="@dingjamma0511" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={`${siteUrl}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Inter font via Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!--
      Dark mode: inline script runs BEFORE first paint to apply the correct
      theme class immediately — prevents flash of unstyled content (FOUC).
    -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var dark = stored === 'dark' || (!stored && prefersDark);
          if (dark) document.documentElement.classList.add('dark');
        } catch (_) {}
      })();
    </script>
  </head>

  <body class="min-h-screen flex flex-col bg-background text-foreground">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
