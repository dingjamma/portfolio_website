---
import Layout from '@/layouts/Layout.astro';
import ProjectCard from '@/components/ProjectCard.astro';

const projects = [
  {
    title: 'NBA Player Prop Predictor — Wembanyama',
    description:
      'Fully automated nightly pipeline predicting Victor Wembanyama\'s prop bets before every Spurs game. Crawls live injury reports, prop lines from 4 sportsbooks (DraftKings, FanDuel, BetMGM, Pinnacle), and the latest news — then runs XGBoost inference across 6 stat categories using 45 engineered features (rolling averages, opponent difficulty, home/away splits). The seed is fed into a MiroFish multi-agent simulation that produces a structured prediction report with OVER/UNDER recommendations. Runs at midnight via a local cron job — zero cloud required.',
    tags: ['Python', 'XGBoost', 'MiroFish', 'Zep GraphRAG', 'qwen-plus', 'Streamlit', 'ESPN API', 'The Odds API'],
    metrics: ['6 XGBoost models', '45 features', 'PTS · REB · AST · STL · BLK · FG3M', 'Fully automated nightly'],
    href: 'https://github.com/dingjamma/NBA-Player-Prop',
    status: 'demo' as const,
  },
  {
    title: 'Calgary Housing Price Predictor',
    description:
      'End-to-end automated intelligence pipeline — no manual downloads. Scrapes 21 years of housing, oil, and economic data; trains three XGBoost models (annual, monthly, daily); scrapes live news via RSS; auto-generates a market intelligence report; and feeds it directly into a MiroFish multi-agent geopolitical simulation. WTI surged $57→$100/barrel in 90 days after US strikes on Iran\'s Kharg Island. The daily Housing Pressure Score currently reads +1.66%. Eight AI agents (Bank of Canada, OPEC+, Iran/IRGC, Calgary buyers, Alberta energy sector) are now simulating December 2026 housing outcomes.',
    tags: ['Python', 'XGBoost', 'pdfplumber', 'yfinance', 'Bank of Canada API', 'MiroFish', 'Zep GraphRAG', 'qwen-plus', 'Streamlit'],
    metrics: ['5,600+ days of daily data', '3 XGBoost models', 'Live pressure score: +1.66%', 'Full MiroFish pipeline'],
    href: 'https://github.com/dingjamma/Calgary-Housing',
    demoHref: 'https://calgary-housing-7phh7dhjyyd2r7mtjymuvm.streamlit.app',
    status: 'demo' as const,
  },
];
---

<Layout
  title="Projects – James Ding"
  description="Data science and ML projects by James Ding — production RAG on AWS, reinforcement learning, and sports analytics."
>

  <div class="section container-lg">

    <!-- Header -->
    <div class="mb-14 max-w-2xl">
      <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-3">Work</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-foreground mb-4">
        Projects
      </h1>
      <p class="text-muted-foreground text-lg leading-relaxed">
        A selection of production systems and open-source projects focused on
        applied machine learning and data analytics.
      </p>
    </div>

    <!-- Project grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      {projects.map(project => (
        <ProjectCard {...project} />
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-16 rounded-xl border border-dashed border-border bg-card/50 p-8 text-center">
      <p class="text-muted-foreground mb-4">
        More projects in progress. Want to collaborate?
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-6 py-2.5 text-sm font-semibold text-primary-foreground hover:bg-primary/90 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
      >
        Get in Touch
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

  </div>
</Layout>
