---
import Layout from '@/layouts/Layout.astro';
import ProjectCard from '@/components/ProjectCard.astro';

const projects = [
  {
    title: 'NBA-Simulverse',
    description:
      'NBA season simulation engine where every player is an autonomous LLM agent with memory, personality, and team chemistry. Each agent reacts to news, develops relationships, and makes decisions that affect game outcomes. Runs hundreds of simulations to capture human behavioral factors that traditional stat models miss.',
    tags: ['Python', 'LLM Agents', 'Multi-Agent Systems', 'Simulation', 'NBA'],
    metrics: ['Autonomous LLM agents', 'Memory + personality', 'Team chemistry model', 'Hundreds of sims'],
    href: 'https://github.com/dingjamma/NBA-Simulverse',
    status: 'demo' as const,
  },
  {
    title: 'NBA Player Prop Predictor — Wembanyama',
    description:
      'Fully automated nightly pipeline predicting Victor Wembanyama\'s prop bets before every Spurs game. Crawls live injury reports, prop lines from 4 sportsbooks (DraftKings, FanDuel, BetMGM, Pinnacle), and the latest news — then runs XGBoost inference across 6 stat categories using 45 engineered features. Produces structured OVER/UNDER prediction reports with confidence levels. Runs at midnight via a local cron job.',
    tags: ['Python', 'XGBoost', 'Streamlit', 'ESPN API', 'The Odds API'],
    metrics: ['6 XGBoost models', '45 features', 'PTS · REB · AST · STL · BLK · FG3M', 'Fully automated nightly'],
    href: 'https://github.com/dingjamma/NBA-Player-Prop',
    status: 'demo' as const,
  },
  {
    title: 'Calgary Housing Intelligence',
    description:
      'Fully automated intelligence pipeline that scrapes 21 years of housing, oil, and economic data; trains three XGBoost models (annual, monthly, daily); scrapes live news via RSS; and auto-generates a market intelligence report with a live Housing Pressure Score. Runs biweekly on the 1st and 15th.',
    tags: ['Python', 'XGBoost', 'pdfplumber', 'yfinance', 'Bank of Canada API', 'Streamlit'],
    metrics: ['5,600+ days of daily data', '3 XGBoost models', 'Live pressure score', 'Automated biweekly'],
    href: 'https://github.com/dingjamma/Calgary-Housing',
    status: 'demo' as const,
  },
  {
    title: 'AI Judge — Supreme Court Prediction',
    description:
      'Supreme Court verdict prediction system using RAG with Claude and FAISS vector search on 200 landmark SCOTUS cases. Retrieves relevant precedents, analyzes case facts, and predicts outcomes while enforcing temporal integrity — the model only sees cases decided before the target case.',
    tags: ['Python', 'Claude API', 'FAISS', 'RAG', 'LangChain', 'Legal AI'],
    metrics: ['200 landmark cases', 'RAG + vector search', 'Temporal integrity', '45.7% accuracy'],
    href: 'https://github.com/dingjamma/ai_judge',
    status: 'demo' as const,
  },
];
---

<Layout
  title="Projects – James Ding"
  description="AI engineering and ML projects by James Ding — production AI agents, RAG systems, and applied machine learning."
>

  <div class="section container-lg">

    <!-- Header -->
    <div class="mb-14 max-w-2xl">
      <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-3">Work</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-foreground mb-4">
        Projects
      </h1>
      <p class="text-muted-foreground text-lg leading-relaxed">
        A selection of production systems and open-source projects focused on
        applied machine learning and data analytics.
      </p>
    </div>

    <!-- Project grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      {projects.map(project => (
        <ProjectCard {...project} />
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-16 rounded-xl border border-dashed border-border bg-card/50 p-8 text-center">
      <p class="text-muted-foreground mb-4">
        More projects in progress. Want to collaborate?
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-6 py-2.5 text-sm font-semibold text-primary-foreground hover:bg-primary/90 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
      >
        Get in Touch
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

  </div>
</Layout>
