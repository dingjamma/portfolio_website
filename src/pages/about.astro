---
import Layout from '@/layouts/Layout.astro';

const skills = [
  // Languages & Querying
  { name: 'Python',           category: 'Core' },
  { name: 'SQL',              category: 'Core' },
  { name: 'TypeScript',       category: 'Core' },

  // Data & ML
  { name: 'Time-Series Forecasting', category: 'ML/Analytics' },
  { name: 'XGBoost / scikit-learn', category: 'ML/Analytics' },
  { name: 'Prophet / ARIMA',  category: 'ML/Analytics' },
  { name: 'PyTorch',          category: 'ML/Analytics' },
  { name: 'EDA & Feature Engineering', category: 'ML/Analytics' },

  // AI & LLMs
  { name: 'RAG Pipelines',    category: 'AI/LLMs' },
  { name: 'LLM Agents',       category: 'AI/LLMs' },
  { name: 'Multi-Agent Systems', category: 'AI/LLMs' },
  { name: 'LangChain',        category: 'AI/LLMs' },
  { name: 'LlamaIndex',       category: 'AI/LLMs' },
  { name: 'FAISS',            category: 'AI/LLMs' },
  { name: 'Ollama',           category: 'AI/LLMs' },
  { name: 'CrewAI',           category: 'AI/LLMs' },
  { name: 'MCP (Model Context Protocol)', category: 'AI/LLMs' },

  // Cloud & Infra
  { name: 'AWS Bedrock',      category: 'Cloud & Infra' },
  { name: 'AWS Lambda',       category: 'Cloud & Infra' },
  { name: 'API Gateway',      category: 'Cloud & Infra' },
  { name: 'OpenSearch Serverless', category: 'Cloud & Infra' },
  { name: 'AWS CDK',          category: 'Cloud & Infra' },
  { name: 'S3',               category: 'Cloud & Infra' },
  { name: 'Snowflake',        category: 'Cloud & Infra' },
  { name: 'Amazon QuickSight',category: 'Cloud & Infra' },
  { name: 'Tableau',          category: 'Cloud & Infra' },
  { name: 'Power BI',         category: 'Cloud & Infra' },

  // DevOps / Backend
  { name: 'GitHub Actions CI/CD', category: 'DevOps' },
  { name: 'Docker / Compose', category: 'DevOps' },
  { name: 'FastAPI',          category: 'DevOps' },
  { name: 'pytest',           category: 'DevOps' },
  { name: 'Git & GitHub',     category: 'DevOps' },

  // Web / Viz
  { name: 'Astro',            category: 'Web' },
  { name: 'React',            category: 'Web' },
  { name: 'Tailwind CSS',     category: 'Web' },

  // Soft / Process
  { name: 'Business Stakeholder Comms', category: 'Process' },
  { name: 'Agile / Scrum',    category: 'Process' },
];

const categoryColors: Record<string, string> = {
  'Core':           'bg-indigo-100 text-indigo-700 border-indigo-200 dark:bg-indigo-900/40 dark:text-indigo-300 dark:border-indigo-800',
  'ML/Analytics':   'bg-violet-100 text-violet-700 border-violet-200 dark:bg-violet-900/40 dark:text-violet-300 dark:border-violet-800',
  'AI/LLMs':        'bg-fuchsia-100 text-fuchsia-700 border-fuchsia-200 dark:bg-fuchsia-900/40 dark:text-fuchsia-300 dark:border-fuchsia-800',
  'Cloud & Infra':  'bg-sky-100   text-sky-700   border-sky-200   dark:bg-sky-900/40   dark:text-sky-300   dark:border-sky-800',
  'DevOps':         'bg-rose-100  text-rose-700  border-rose-200  dark:bg-rose-900/40  dark:text-rose-300  dark:border-rose-800',
  'Web':            'bg-emerald-100 text-emerald-700 border-emerald-200 dark:bg-emerald-900/40 dark:text-emerald-300 dark:border-emerald-800',
  'Process':        'bg-amber-100 text-amber-700 border-amber-200 dark:bg-amber-900/40 dark:text-amber-300 dark:border-amber-800',
};

const experience = [
  {
    title:    'Associate Data Analyst',
    company:  'AirSprint Private Aviation',
    period:   'May 2025 – Present',
    location: 'Calgary, AB',
    bullets: [
      'Designed and shipped a production time-series forecasting model (Prophet, with LSTM experiments) for revenue flight-hour planning.',
      'Achieved 6% weekly MAPE and 2% monthly MAPE in production; 40% error reduction vs. backtest baseline.',
      'Addressed $49M empty-leg cost exposure, identifying $5M–$10M savings opportunity for the operations team.',
      'Built Snowflake data pipelines and Amazon QuickSight dashboards consumed by executive stakeholders.',
      'Resolved UTC timestamp ingestion bugs and developed volatility-aware smoothing strategies for noisy ops data.',
    ],
  },
  {
    title:    'Data Analyst Intern',
    company:  'AirSprint Private Aviation',
    period:   '2024',
    location: 'Calgary, AB',
    bullets: [
      'Supported EDA and baseline modelling for flight-hour demand, laying the groundwork for the production forecaster.',
      'Authored SQL queries in Snowflake for ad-hoc reporting and KPI tracking.',
      'Collaborated with operations and finance teams to translate business questions into analytical deliverables.',
    ],
  },
];
---

<Layout
  title="About – James Ding"
  description="Learn about James Ding's background: MDSA, University of Calgary. Data science across aviation, logistics, and agriculture."
>

  <div class="section container-lg">

    <!-- Page header -->
    <div class="mb-16 max-w-2xl">
      <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-3">About</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-foreground mb-6">
        James Ding
      </h1>

      <!-- Professional summary -->
      <div class="prose prose-slate dark:prose-invert max-w-none space-y-4 text-muted-foreground leading-relaxed">
        <p>
          I'm a data scientist and aspiring AI engineer who builds end-to-end ML systems and AI-powered pipelines.
          Currently working as an Associate Data Analyst at <strong class="text-foreground">AirSprint Private Aviation</strong>,
          where I specialize in <strong class="text-foreground">time-series forecasting, SQL optimization, and data modeling in Snowflake.</strong>
          I hold an <strong class="text-foreground">MDSA (Master of Data Science and Analytics)</strong> from the University of Calgary.
        </p>
        <p>
          I'm drawn to complex systems — whether that's building autonomous trading bots on AWS Lambda,
          training XGBoost models that track how oil prices drive Calgary housing, or building RAG systems
          that predict Supreme Court verdicts. I enjoy the full lifecycle: from messy exploratory analysis
          to production-ready AI systems.
        </p>
        <p>
          Recent work:
        </p>
        <ul>
          <li>Built Polybot — an autonomous Polymarket trading bot on AWS Lambda using a Haiku→Sonnet Claude cascade with an insider-trading detector</li>
          <li>Overhauled Calgary Housing Intelligence — 3 XGBoost models, live pressure score, 8-agent geopolitical simulation</li>
          <li>Built AI Judge — Supreme Court verdict prediction using RAG with Claude and FAISS on 200 landmark cases</li>
          <li>Working through 93 AI engineering projects covering LLMs, RAG, agents, MCP, and fine-tuning</li>
        </ul>
      </div>
    </div>

    <!-- Two-column layout: Education + Skills | Experience -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">

      <!-- Left column: Education + Skills -->
      <div class="lg:col-span-1 space-y-12">

        <!-- Education -->
        <section>
          <h2 class="text-sm font-semibold text-primary uppercase tracking-widest mb-6">Education</h2>

          <div class="space-y-3">
            <div class="rounded-xl border border-border bg-card p-6">
              <div class="flex items-start gap-4">
                <div class="shrink-0 h-10 w-10 rounded-md bg-primary/10 flex items-center justify-center">
                  <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M12 14l9-5-9-5-9 5 9 5z"/>
                    <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-foreground">MDSA — Master of Data Science and Analytics</p>
                  <p class="text-sm text-primary mt-0.5">University of Calgary</p>
                  <p class="text-xs text-muted-foreground mt-1">Calgary, AB, Canada</p>
                </div>
              </div>
            </div>

            <div class="rounded-xl border border-border bg-card p-6">
              <div class="flex items-start gap-4">
                <div class="shrink-0 h-10 w-10 rounded-md bg-primary/10 flex items-center justify-center">
                  <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M12 14l9-5-9-5-9 5 9 5z"/>
                    <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-foreground">BSc — Agricultural and Consumer Economics</p>
                  <p class="text-sm text-primary mt-0.5">University of Illinois Urbana-Champaign</p>
                  <p class="text-xs text-muted-foreground mt-1">Champaign, IL, USA</p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Skills -->
        <section>
          <h2 class="text-sm font-semibold text-primary uppercase tracking-widest mb-6">Skills</h2>
          <div class="flex flex-wrap gap-2">
            {skills.map(({ name, category }) => (
              <span class={`inline-flex items-center rounded-md border px-2.5 py-1 text-xs font-medium ${categoryColors[category]}`}>
                {name}
              </span>
            ))}
          </div>

          <!-- Legend -->
          <div class="mt-4 flex flex-wrap gap-3">
            {Object.entries(categoryColors).map(([cat, cls]) => (
              <span class={`inline-flex items-center rounded-md border px-2 py-0.5 text-[10px] font-semibold ${cls}`}>
                {cat}
              </span>
            ))}
          </div>
        </section>
      </div>

      <!-- Right column: Experience timeline -->
      <div class="lg:col-span-2">
        <h2 class="text-sm font-semibold text-primary uppercase tracking-widest mb-6">Experience</h2>

        <div class="relative space-y-8">
          {/* Timeline line */}
          <div class="absolute left-5 top-2 bottom-2 w-px bg-border hidden sm:block" aria-hidden="true"></div>

          {experience.map((exp, i) => (
            <div class="relative sm:pl-14">
              {/* Timeline dot */}
              <div class="hidden sm:flex absolute left-0 top-1 h-10 w-10 items-center justify-center rounded-full border-2 border-primary bg-background z-10">
                <span class="text-xs font-bold text-primary">{experience.length - i}</span>
              </div>

              <div class="rounded-xl border border-border bg-card p-6 hover:border-primary/40 transition-colors">
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-4">
                  <div>
                    <h3 class="font-bold text-foreground">{exp.title}</h3>
                    <p class="text-sm text-primary font-medium">{exp.company}</p>
                  </div>
                  <div class="text-right">
                    <p class="text-xs font-semibold text-muted-foreground whitespace-nowrap">{exp.period}</p>
                    <p class="text-xs text-muted-foreground">{exp.location}</p>
                  </div>
                </div>

                <ul class="space-y-2">
                  {exp.bullets.map(bullet => (
                    <li class="flex items-start gap-2 text-sm text-muted-foreground">
                      <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-primary/60"></span>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</Layout>
