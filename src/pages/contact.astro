---
import Layout from '@/layouts/Layout.astro';

const socials = [
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/jam-ding',
    href: 'https://linkedin.com/in/jam-ding',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 shrink-0"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: 'GitHub',
    value: 'github.com/dingjamma',
    href: 'https://github.com/dingjamma',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 shrink-0"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  },
  {
    label: 'X / Twitter',
    value: '@dingjamma0511',
    href: 'https://x.com/dingjamma0511',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 shrink-0"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.261 5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
];
---

<Layout
  title="Contact – James Ding"
  description="Get in touch with James Ding. Connect on LinkedIn, GitHub, or email directly."
>

  <div class="section container-lg">

    <!-- Header -->
    <div class="mb-14 max-w-xl">
      <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-3">Get in touch</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-foreground mb-4">
        Contact
      </h1>
      <p class="text-muted-foreground text-lg leading-relaxed">
        Have a project idea, want to collaborate, or just want to chat about data science?
        Reach out — I'm always happy to connect.
      </p>
    </div>

    <div class="max-w-lg space-y-4">

      <!-- Email CTA (primary) -->
      <a
        href="mailto:james@dingjames.com"
        class="flex items-center gap-4 rounded-xl border-2 border-primary/40 bg-primary/5 p-5 hover:border-primary hover:bg-primary/10 transition-all group"
      >
        <span class="shrink-0 h-11 w-11 rounded-lg bg-primary/15 flex items-center justify-center text-primary group-hover:bg-primary/25 transition-colors">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5 shrink-0">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        </span>
        <div class="min-w-0">
          <p class="text-xs text-muted-foreground mb-0.5">Email — preferred</p>
          <p class="text-sm font-semibold text-foreground group-hover:text-primary transition-colors">james@dingjames.com</p>
        </div>
        <svg class="h-4 w-4 text-muted-foreground ml-auto shrink-0 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>

      <!-- Other socials -->
      {socials.map(({ label, value, href, icon }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 rounded-xl border border-border bg-card p-5 hover:border-primary/50 hover:shadow-sm transition-all group"
        >
          <span class="shrink-0 h-11 w-11 rounded-lg bg-muted flex items-center justify-center text-muted-foreground group-hover:text-primary group-hover:bg-primary/10 transition-colors">
            <Fragment set:html={icon} />
          </span>
          <div class="min-w-0">
            <p class="text-xs text-muted-foreground mb-0.5">{label}</p>
            <p class="text-sm font-semibold text-foreground group-hover:text-primary transition-colors truncate">{value}</p>
          </div>
          <svg class="h-4 w-4 text-muted-foreground ml-auto shrink-0 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      ))}

      <!-- Open to work note -->
      <div class="rounded-xl border border-primary/30 bg-primary/5 p-5 mt-6">
        <h3 class="font-semibold text-foreground mb-1.5 flex items-center gap-2 text-sm">
          <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
          Open to Opportunities
        </h3>
        <p class="text-sm text-muted-foreground leading-relaxed">
          Open to AI Engineer and ML Engineer roles.
        </p>
      </div>

    </div>

  </div>
</Layout>
