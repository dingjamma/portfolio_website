---
export interface Props {
  title: string;
  description: string;
  tags: string[];
  href: string;
  metrics?: string[];
  status?: 'production' | 'demo' | 'wip';
  external?: boolean;
}

const {
  title,
  description,
  tags,
  href,
  metrics = [],
  status = 'demo',
  external = false,
} = Astro.props;

const statusConfig = {
  production: { label: 'Production', class: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300' },
  demo:       { label: 'Demo',       class: 'bg-blue-100   text-blue-700   dark:bg-blue-900/40   dark:text-blue-300'   },
  wip:        { label: 'WIP',        class: 'bg-amber-100  text-amber-700  dark:bg-amber-900/40  dark:text-amber-300'  },
};
const st = statusConfig[status];
---

<a
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class="group flex flex-col rounded-xl border border-border bg-card hover:border-primary/50 hover:shadow-md transition-all duration-300 overflow-hidden"
>
  <div class="flex-1 p-6">

    <!-- Header row -->
    <div class="flex items-start justify-between gap-3 mb-4">
      <span class={`inline-flex items-center rounded-md px-2.5 py-0.5 text-xs font-semibold ${st.class}`}>
        {st.label}
      </span>

      <!-- External link icon -->
      {external && (
        <svg class="h-4 w-4 text-muted-foreground shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6m0 0v6m0-6L10 14" />
        </svg>
      )}
      {!external && (
        <svg class="h-4 w-4 text-muted-foreground group-hover:text-primary shrink-0 translate-x-0 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      )}
    </div>

    <!-- Title -->
    <h3 class="text-lg font-bold text-foreground group-hover:text-primary transition-colors mb-2">
      {title}
    </h3>

    <!-- Description -->
    <p class="text-sm text-muted-foreground leading-relaxed">
      {description}
    </p>

    <!-- Metrics -->
    {metrics.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {metrics.map(m => (
          <span class="inline-flex items-center rounded-md px-2.5 py-0.5 text-xs font-semibold bg-indigo-100 text-indigo-700 dark:bg-indigo-900/40 dark:text-indigo-300">
            {m}
          </span>
        ))}
      </div>
    )}
  </div>

  <!-- Tags footer -->
  <div class="border-t border-border px-6 py-4">
    <div class="flex flex-wrap gap-2">
      {tags.map(tag => (
        <span class="text-xs px-2 py-1 rounded bg-secondary text-secondary-foreground font-mono">
          {tag}
        </span>
      ))}
    </div>
  </div>
</a>
