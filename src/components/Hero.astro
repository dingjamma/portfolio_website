---
// Hero section for the home page
---

<section class="relative overflow-hidden py-24 sm:py-32 lg:py-40 px-4 sm:px-6 lg:px-8">

  <!-- Subtle background gradient blobs -->
  <div
    class="pointer-events-none absolute -top-40 -left-40 h-[500px] w-[500px] rounded-full opacity-20 dark:opacity-10"
    style="background: radial-gradient(circle, oklch(0.512 0.244 264) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute -bottom-40 -right-40 h-[400px] w-[400px] rounded-full opacity-15 dark:opacity-10"
    style="background: radial-gradient(circle, oklch(0.618 0.220 264) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-4xl mx-auto">

    <!-- Eyebrow label -->
    <div class="mb-6 flex items-center gap-3">
      <span class="h-px flex-1 max-w-[60px] bg-primary/40"></span>
      <span class="text-sm font-medium text-primary tracking-widest uppercase">
        Data Scientist
      </span>
    </div>

    <!-- Name -->
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-foreground">
      Jiajian Ding
    </h1>

    <!-- Title line with gradient -->
    <p class="mt-4 text-xl sm:text-2xl lg:text-3xl font-semibold gradient-text">
      Aviation Analytics Specialist
    </p>

    <!-- Bio -->
    <p class="mt-6 max-w-2xl text-base sm:text-lg text-muted-foreground leading-relaxed text-balance">
      MSc Data Science from the University of Calgary. Experienced in
      production time-series forecasting for private aviation operations.
      Passionate about predictive analytics that drive real business impact.
    </p>

    <!-- CTA buttons -->
    <div class="mt-10 flex flex-col sm:flex-row gap-4">
      <a
        href="/projects"
        class="inline-flex items-center justify-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-semibold text-primary-foreground shadow hover:bg-primary/90 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
      >
        View Projects
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>

      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-semibold text-foreground shadow-sm hover:bg-accent hover:text-accent-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
      >
        Contact Me
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
        </svg>
      </a>
    </div>

    <!-- Featured project teaser card -->
    <div class="mt-20">
      <p class="text-xs font-semibold text-muted-foreground uppercase tracking-widest mb-4">
        Featured Project
      </p>

      <a
        href="/projects/forecasting"
        class="group block rounded-xl border border-border bg-card hover:border-primary/50 hover:shadow-lg transition-all duration-300 overflow-hidden"
      >
        <div class="p-6 sm:p-8">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
            <div class="flex-1">
              <!-- Badges -->
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="inline-flex items-center rounded-md px-2.5 py-0.5 text-xs font-semibold bg-indigo-100 text-indigo-700 dark:bg-indigo-900/40 dark:text-indigo-300">
                  Production
                </span>
                <span class="inline-flex items-center rounded-md px-2.5 py-0.5 text-xs font-semibold bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300">
                  6% MAPE weekly
                </span>
                <span class="inline-flex items-center rounded-md px-2.5 py-0.5 text-xs font-semibold bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300">
                  40% error reduction
                </span>
              </div>

              <h2 class="text-xl font-bold text-foreground group-hover:text-primary transition-colors">
                Aviation Revenue Hours Forecasting
              </h2>
              <p class="mt-2 text-sm text-muted-foreground leading-relaxed">
                Built and deployed a production time-series forecasting model for revenue flight
                hours at AirSprint. Addressed <strong class="text-foreground">$49M</strong> empty
                leg cost exposure with a <strong class="text-foreground">$5M–$10M</strong> savings
                opportunity identified.
              </p>

              <div class="mt-4 flex flex-wrap gap-2">
                {['Python', 'Snowflake', 'Prophet', 'LSTM', 'QuickSight'].map(t => (
                  <span class="text-xs px-2 py-1 rounded bg-secondary text-secondary-foreground font-mono">
                    {t}
                  </span>
                ))}
              </div>
            </div>

            <!-- Arrow -->
            <div class="shrink-0 self-center">
              <div class="h-10 w-10 rounded-full border border-border flex items-center justify-center text-muted-foreground group-hover:border-primary group-hover:text-primary group-hover:bg-primary/10 transition-all">
                <svg class="h-4 w-4 translate-x-0 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </div>
        </div>
      </a>
    </div>

  </div>
</section>
