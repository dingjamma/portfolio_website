---
// Hero section for the home page
---

<section class="relative overflow-hidden py-24 sm:py-32 lg:py-40 px-4 sm:px-6 lg:px-8">

  <!-- Subtle background gradient blobs -->
  <div
    class="pointer-events-none absolute -top-40 -left-40 h-[500px] w-[500px] rounded-full opacity-20 dark:opacity-10"
    style="background: radial-gradient(circle, oklch(0.90 0.12 165) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute -bottom-40 -right-40 h-[400px] w-[400px] rounded-full opacity-15 dark:opacity-10"
    style="background: radial-gradient(circle, oklch(0.75 0.14 165) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-5xl mx-auto">

    <!-- Two-column layout: text left, photo right -->
    <div class="flex flex-col-reverse lg:flex-row lg:items-center lg:gap-16 gap-12">

      <!-- ── Left: text content ── -->
      <div class="flex-1 min-w-0">

        <!-- Eyebrow label -->
        <div class="mb-6 flex items-center gap-3">
          <span class="h-px flex-1 max-w-[60px] bg-primary/40"></span>
          <span class="text-sm font-medium text-primary tracking-widest uppercase">
            Data Scientist · Analyst
          </span>
        </div>

        <!-- Name -->
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-foreground">
          James Ding
        </h1>

        <!-- Title line with gradient + TN badge -->
        <div class="mt-4 flex flex-wrap items-center gap-3">
          <p class="text-xl sm:text-2xl lg:text-3xl font-semibold gradient-text">
            Data Scientist
          </p>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-primary/30 bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
            <svg class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" />
            </svg>
            TN Visa Eligible · No Sponsorship Required
          </span>
        </div>

        <!-- Bio -->
        <p class="mt-6 max-w-2xl text-base sm:text-lg text-muted-foreground leading-relaxed text-balance">
          MDSA from the University of Calgary. Background in private aviation, logistics,
          and agriculture — I understand operational data from the ground up. I build
          end-to-end ML systems: from messy raw data to deployed models that drive real decisions.
          Currently shipping production forecasting at AirSprint and open to Data Science, AI Engineer, and ML Engineer roles.
        </p>

        <!-- CTA buttons + social icons -->
        <div class="mt-10 flex flex-col sm:flex-row sm:items-center gap-4">
          <a
            href="/projects"
            class="inline-flex items-center justify-center gap-2 rounded-md bg-primary px-8 py-3 text-sm font-semibold text-primary-foreground shadow hover:bg-primary/90 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
          >
            View Projects
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>

          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 rounded-md border border-input bg-background px-8 py-3 text-sm font-semibold text-foreground shadow-sm hover:bg-accent hover:text-accent-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
          >
            Contact Me
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </a>

          <a
            href="/JamesDing_Resume.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-md border border-input bg-background px-5 py-3 text-sm font-semibold text-foreground shadow-sm hover:bg-accent hover:text-accent-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z" />
            </svg>
            Resume
          </a>

          <!-- Social icon links -->
          <div class="flex items-center gap-2 sm:ml-1">
            <a
              href="https://github.com/dingjamma"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub"
              class="inline-flex items-center justify-center h-10 w-10 rounded-md border border-input bg-background text-muted-foreground hover:text-foreground hover:border-primary/50 transition-colors"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
              </svg>
            </a>
            <a
              href="https://linkedin.com/in/jam-ding"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
              class="inline-flex items-center justify-center h-10 w-10 rounded-md border border-input bg-background text-muted-foreground hover:text-foreground hover:border-primary/50 transition-colors"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            </a>
          </div>
        </div>

      </div>

      <!-- ── Right: photo ── -->
      <div class="flex lg:justify-end justify-center shrink-0">
        <div class="relative">
          <!-- Glow ring behind photo -->
          <div class="absolute inset-0 rounded-full bg-primary/20 blur-2xl scale-110" aria-hidden="true"></div>
          <img
            src="/image.jpg"
            alt="James Ding"
            width="280"
            height="280"
            class="relative h-52 w-52 sm:h-64 sm:w-64 lg:h-72 lg:w-72 rounded-2xl object-cover object-top shadow-2xl ring-2 ring-primary/30"
          />
        </div>
      </div>

    </div>

    <!-- Featured project -->
    <div class="mt-20">
      <p class="text-xs font-semibold text-muted-foreground uppercase tracking-widest mb-4">
        Featured Project
      </p>

      <div class="rounded-xl border border-primary/40 bg-card hover:border-primary/70 hover:shadow-xl transition-all duration-300 overflow-hidden">
        <div class="p-6 sm:p-8 flex flex-col gap-5">

          <!-- Badges -->
          <div class="flex flex-wrap gap-2">
            <span class="inline-flex items-center rounded-md px-2.5 py-0.5 text-xs font-semibold bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300">
              In Progress
            </span>
            <span class="inline-flex items-center rounded-md px-2.5 py-0.5 text-xs font-semibold bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300">
              Forecasting · XGBoost · Live Data
            </span>
          </div>

          <!-- Title + description -->
          <div>
            <h2 class="text-xl font-bold text-foreground">Calgary Housing Price Predictor</h2>
            <p class="mt-2 text-sm text-muted-foreground leading-relaxed max-w-3xl">
              Full automated data pipeline — no manual downloads. Scrapes CREB monthly PDFs, City of Calgary assessed values (2005–2025),
              Bank of Canada rates, and daily WTI oil prices to predict Calgary housing benchmark prices.
              Three XGBoost models at annual, monthly, and <strong class="text-foreground">daily resolution</strong> — including a live Housing Pressure Score
              that flipped negative on March 10 as oil crossed $83, now reading <strong class="text-foreground">-0.13% at $100/barrel</strong>.
              Integrates MiroFish geopolitical simulation: the Kharg Island scenario that predicted the current oil spike same-day.
            </p>
          </div>

          <!-- Metrics -->
          <div class="flex flex-wrap gap-2">
            {['5,600+ days of daily data', '3 XGBoost models', 'Live pressure score', 'Oil at $100 today', '2005–2026 coverage'].map(m => (
              <span class="inline-flex items-center rounded-md px-2.5 py-0.5 text-xs font-semibold bg-primary/10 text-primary">{m}</span>
            ))}
          </div>

          <!-- Tags + actions -->
          <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
            <div class="flex flex-wrap gap-2">
              {['Python', 'XGBoost', 'pdfplumber', 'yfinance', 'Bank of Canada API', 'MiroFish', 'Pandas'].map(t => (
                <span class="text-xs px-2 py-1 rounded bg-secondary text-secondary-foreground font-mono">{t}</span>
              ))}
            </div>
            <a href="https://github.com/dingjamma/Calgary-Housing" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 rounded-md border border-border px-3 py-1.5 text-xs font-semibold text-muted-foreground hover:text-foreground hover:border-primary/50 transition-colors shrink-0">
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
              GitHub
            </a>
          </div>

        </div>
      </div>
    </div>

    <!-- Work Highlight -->
    <div class="mt-8">
      <p class="text-xs font-semibold text-muted-foreground uppercase tracking-widest mb-4">
        Work Highlight
      </p>

      <div class="rounded-xl border border-border bg-card hover:border-primary/50 hover:shadow-lg transition-all duration-300 overflow-hidden">
        <div class="p-6 sm:p-8">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
            <div class="flex-1">
              <div class="flex flex-wrap gap-2 mb-3">
                <span class="inline-flex items-center rounded-md px-2.5 py-0.5 text-xs font-semibold bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-300">
                  Production
                </span>
                <span class="inline-flex items-center rounded-md px-2.5 py-0.5 text-xs font-semibold bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300">
                  Forecasting · ETL
                </span>
              </div>
              <h2 class="text-lg font-bold text-foreground">Flight Hour Forecasting — AirSprint Private Aviation</h2>
              <p class="mt-2 text-sm text-muted-foreground leading-relaxed max-w-2xl">
                Built and deployed a Prophet forecasting model on 12 years of private aviation data
                (78K+ flights). Achieved 6% weekly MAPE in live production, reducing positioning costs
                by $490K+. Architected automated ingestion pipelines (FL3XX, Salesforce, Foreflight →
                Lambda → S3 → Snowflake) and QuickSight dashboards for executive stakeholders.
              </p>
              <div class="flex flex-wrap gap-2 mt-4">
                {['Python', 'Prophet', 'Snowflake', 'AWS Lambda', 'QuickSight', 'HTML Dashboard', 'SQL'].map(t => (
                  <span class="text-xs px-2 py-1 rounded bg-secondary text-secondary-foreground font-mono">{t}</span>
                ))}
              </div>
            </div>
            <div class="shrink-0">
              <a href="/about"
                class="inline-flex items-center gap-1.5 rounded-md border border-border px-3 py-1.5 text-xs font-semibold text-muted-foreground hover:text-foreground hover:border-primary/50 transition-colors whitespace-nowrap">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                </svg>
                About Me
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
